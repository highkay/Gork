# Gork environment example
#
# 用法：
# 1. 复制为 .env 后按需修改
# 2. 启动期 / 部署期变量放这里
# 3. 常规运行时配置优先改 ${DATA_DIR}/config.toml


# ==================== 基础运行 ====================
TZ=Asia/Shanghai
LOG_LEVEL=INFO
# 写入本地文件日志
LOG_FILE_ENABLED=true
# 账号目录增量同步间隔（秒）
ACCOUNT_SYNC_INTERVAL=30

# Vercel / serverless 模式：禁用常驻后台 loop，改用内部维护接口和 Cron 触发
# GORK_RUNTIME_MODE=serverless
# CRON_SECRET=replace-with-a-long-random-secret


# ==================== Web 服务 / Docker Compose ====================
# Go binary listens on HOST:PORT.
HOST=0.0.0.0
PORT=8000

# Legacy Python/Granian names are still accepted by Docker Compose fallbacks.
# Keep them only while older compose files or deployment templates still refer to them.
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
# SERVER_WORKERS is deprecated in the Go runtime and has no effect.
# SERVER_WORKERS=1

# Docker Compose 宿主机映射端口
HOST_PORT=8000


# ==================== 账号存储（启动期） ====================
# 可选：local | redis | mysql | postgresql
# Vercel 部署时通常不要手动设置 ACCOUNT_STORAGE，连接 Marketplace 存储后会自动识别：
# - PostgreSQL/Neon/Supabase: POSTGRES_URL / POSTGRES_PRISMA_URL / DATABASE_URL 等
# - MySQL: MYSQL_URL，或 scheme 为 mysql:// 的 DATABASE_URL
# - Upstash Redis / Vercel KV: REDIS_URL / KV_URL，或 REST URL + TOKEN
ACCOUNT_STORAGE=local

# redis: Redis DSN（ACCOUNT_STORAGE=redis 时必填）
# ACCOUNT_REDIS_URL=redis://:password@host:6379/0
# Vercel KV / Upstash REST（自动识别；二选一即可）
# UPSTASH_REDIS_REST_URL=https://example.upstash.io
# UPSTASH_REDIS_REST_TOKEN=replace-with-token
# KV_REST_API_URL=https://example.upstash.io
# KV_REST_API_TOKEN=replace-with-token

# Redis runtime（可选）：用于后台任务快照、scheduler leader 锁等运行时协调
# 留空时使用本地进程内状态；若已配置 ACCOUNT_REDIS_URL / Vercel KV / Upstash REST，可自动复用
# RUNTIME_REDIS_URL=redis://:password@host:6379/0
# RUNTIME_TASK_TTL_S=300
# RUNTIME_REDIS_LOCK_TTL_MS=300000

# mysql: Go DSN 或兼容的 mysql:// / mysql+aiomysql:// URL
# ACCOUNT_MYSQL_URL=user:password@tcp(127.0.0.1:3306)/gork?parseTime=true
# ACCOUNT_MYSQL_URL=mysql://user:password@127.0.0.1:3306/gork
# Vercel Marketplace 常见注入变量：MYSQL_URL

# postgresql: Go/libpq URL；兼容 postgresql+asyncpg:// 前缀
# ACCOUNT_POSTGRESQL_URL=postgres://user:password@127.0.0.1:5432/gork?sslmode=disable
# ACCOUNT_POSTGRESQL_URL=postgresql+asyncpg://user:password@127.0.0.1:5432/gork
# Vercel Marketplace 常见注入变量：POSTGRES_URL / POSTGRES_PRISMA_URL / DATABASE_URL

# SQL 连接池（mysql / postgresql 模式，以下均为默认值，无需改动即可生效）
# ACCOUNT_SQL_POOL_SIZE=5
# ACCOUNT_SQL_MAX_OVERFLOW=10
# ACCOUNT_SQL_POOL_TIMEOUT=30
# ACCOUNT_SQL_POOL_RECYCLE=1800


# ==================== 可选：本地数据 / 日志目录 ====================
DATA_DIR=./data
LOG_DIR=./logs
